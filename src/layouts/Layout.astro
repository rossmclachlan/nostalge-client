---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = 'Nostalge — your record crate' } = Astro.props

// Normalise the base path (strip any trailing slash) so we can build
// absolute URLs that resolve under /nostalge-client/ on GitHub Pages.
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const manifestHref = `${base}/manifest.webmanifest`
const swPath = `${base}/sw.js`
const swScope = `${base}/`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0"
    />
    <meta name="theme-color" content="#1b1712" />
    <meta
      name="description"
      content="A record crate for rediscovering the music you already own."
    />
    <link rel="icon" type="image/svg+xml" href={`${base}/icon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/icon-192.png`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- PWA manifest (registration is wired below) -->
    <link rel="manifest" href={manifestHref} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Bebas+Neue&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script is:inline define:vars={{ swPath, swScope }}>
      // Register the Workbox-generated service worker. Fails silently so a
      // browser without SW support (or a blocked registration) never breaks
      // the app — it just won't be installable/offline-cached.
      if ('serviceWorker' in navigator) {
        let refreshing = false
        // Whether the page is already controlled by a SW. On a brand-new
        // install there's no controller yet, so we skip the reload that the
        // initial clientsClaim would otherwise trigger on a first visit.
        const hadController = !!navigator.serviceWorker.controller

        // registerType:'autoUpdate' makes a new SW skipWaiting + clientsClaim,
        // which fires `controllerchange` once the updated version takes over.
        // Reload once so the page actually runs the new build (no manual
        // hard-refresh needed after a deploy).
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          if (refreshing || !hadController) return
          refreshing = true
          window.location.reload()
        })

        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register(swPath, { scope: swScope })
            .then((reg) => {
              // Check for a newer SW whenever the app is brought back to the
              // foreground, so reopening it picks up the latest deploy.
              document.addEventListener('visibilitychange', () => {
                if (document.visibilityState === 'visible') reg.update()
              })
            })
            .catch(() => {})
        })
      }
    </script>
  </body>
</html>
