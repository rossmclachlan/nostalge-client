---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = 'Nostalge — your record crate' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0"
    />
    <meta name="theme-color" content="#1b1712" />
    <meta
      name="description"
      content="A record crate for rediscovering the music you already own."
    />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/icon.svg`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/icon-192.png`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Bebas+Neue&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
